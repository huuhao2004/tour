// Top Header
.top-header
  .container
    .inner-wrap
      .inner-item
        i.fa-solid.fa-phone
        | #{String(settingSettingInfo.phone).replace(/(\d{3})(\d{3})(\d+)/, "$1.$2.$3")}
      .inner-item
        i.fa-solid.fa-envelope
        | #{settingSettingInfo.email}
      .inner-item
        i.fa-solid.fa-building
        | #{settingSettingInfo.address}
// End Top Header
// Header
header.header
  .container
    .inner-wrap
      .inner-logo
        a(href="/")
          img(
            alt=settingSettingInfo.websiteName
            src=settingSettingInfo.logo
            )
          p 37.TRAVEL
      nav.inner-menu
        ul
          li
            a.active(href="/") Trang chủ
          each item in categoryList
              li
                a(href=`/category/${item.slug}`) #{item.name}
                if(item.children)
                i.fa-solid.fa-caret-down
                ul
                  each itemChild in item.children
                    li
                      a.active(href=`/category/${itemChild.slug}`) #{itemChild.name} 
          li
            a(href="#") Tin tức
          li
            a(href="#") Liên hệ
      .inner-cart
        a(href="/cart")
          i.fa-solid.fa-cart-shopping
          span 1
// End header