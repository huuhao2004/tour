extends ../layouts/default.pug
include ../mixins/box-breadcrump.pug
include ../mixins/product-item.pug

block main

  // Box Breadcrumb
  -
    var breadcrumb = {
      image: "/assets/images/banner6.jpg",
      title: "Tour nước ngoài",
      list: [
        {
          link: "/",
          title: "Trang chủ"
        },
        {
          link: "/tours",
          title: "Tour nước ngoài"
        }
      ]
    }
  
  +box-breadcrumb(breadcrumb)
  // Box Breadcrumb



  // Section 9
  -
    var productListSection9 = [
      {
        "avatar": "/assets/images/product1.jpg", 
        "slug" : "",
        "discount": 30,
        "name" : "Hà Nội – Lào Cai – SaPa 4N3Đ",
        "priceOld" : 13650000,
        "priceNew": 2590000,
        "code" : "TOUR000001",
        "departureDate": "22/07/2024",
        "time": "10 Ngày 9 Đêm",
        "ratingStar": 4,
        "ratingTotal": 20,
        "stock": 10
      },
      {
        "avatar": "/assets/images/product2.jpg", 
        "slug" : "",
        "discount": 0,
        "name" : "Tour 2024 Phú Quốc – Thiên Đường Đảo Ngọc (3N2D)",
        "priceOld" : 13650000,
        "priceNew": 2590000,
        "code" : "TOUR000001",
        "departureDate": "22/07/2024",
        "time": "10 Ngày 9 Đêm",
        "ratingStar": 3,
        "ratingTotal": 20,
        "stock": 10
      }
    ]
  .section-9
    .container
      .inner-wrap
        .inner-left
          // Box filter
          .box-filter
            .inner-head
              .inner-title Bộ lọc
              i.fa-solid.fa-filter
            .inner-body
              .inner-group
                label.inner-label(for="") Điểm đi
                select(name="")
                  option(value="") -- Chọn điểm đi --
                  option(value="") Hà Nội
                  option(value="") Đà Nẵng
                  option(value="") Nha Trang
              .inner-group
                label.inner-label(for="") Điểm đến
                select(name="")
                  option(value="") -- Chọn điểm đến --
                  option(value="") Hà Nội
                  option(value="") Đà Nẵng
                  option(value="") Nha Trang
              .inner-group
                label.inner-label(for="") Ngày khởi hành
                input(
                  name="" 
                  type="date"
                  )
              .inner-group
                label.inner-label(for="") Số lượng hành khách
                .inner-input-list
                  .inner-input-item
                    span Người lớn:
                    input(
                      value="0" 
                      name="" 
                      type="number"
                      )
                  .inner-input-item
                    span Trẻ em:
                    input(
                      value="0" 
                      name="" 
                      type="number"
                      )
                  .inner-input-item
                    span Em bé:
                    input(
                      value="0" 
                      name="" 
                      type="number"
                      )
              .inner-group
                label.inner-label(for="") Mức giá
                select(name="")
                  option(value="") -- Chọn khoảng giá --
                  option(value="") Dưới 1tr
                  option(value="") Từ 1tr đến 3tr
                  option(value="") Từ 3tr đến 6tr
                  option(value="") Từ 6tr đến 10tr
                  option(value="") Trên 10tr
              .inner-group
                button.inner-button Áp dụng
          // End box fiter
        .inner-right
          .inner-info
            h2.inner-title Tour Nước Ngoài
            .inner-desc
              | Du lịch Châu Á: là châu lục lớn và đông dân nhất thế giới. Châu Á cũng có nhiều danh lam thắng cảnh đẹp tại một số quốc
              |   gia như Hàn Quốc, Nhật Bản, Trung Quốc, Việt Nam,... và VK Travel là nhà tổ chức du lịch chuyên nghiệp hàng đầu Châu Á,
              |   đã 5 lần liên tiếp nhận giải TTG Travel Awards. Hãy cùng 28.Travel du lịch Châu Á để tận hưởng những dịch vụ tốt nhất.
          .inner-info-2
            .inner-sort
              .inner-label Sắp xếp:
              .inner-list
                button
                  | Giá tăng dần
                  i.fa-solid.fa-square-caret-up
                button
                  | Giá giảm dần
                  i.fa-solid.fa-square-caret-down
                button.active
                  | Khuyến mãi hot
                  i.fa-solid.fa-tag
                button
                  | Xem nhiều
                  i.fa-solid.fa-eye
            .inner-count-record
              | Tất cả:
              b 101
          .inner-list-tour
            each item in productListSection9 
              +product-item(item)
          // Pagination
          .box-pagination
            button
              i.fa-solid.fa-angles-left
            button.active 1
            button 2
            button 3
            button 4
            button
              i.fa-solid.fa-angles-right
          // End pagination
  // End section 9