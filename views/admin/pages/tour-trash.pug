extends ../layouts/default.pug

block main 
  h1.box-title Thùng rác tour

  //- Section 5
  .section-5 
    .inner-wrap 
      .inner-change-status
        .inner-item 
          select
            option(value="") -- Hành động --
            option(value="") Khôi phục
            option(value="") Xóa vĩnh viến
        .inner-item 
          button Áp dụng
      .inner-search 
        <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm")
  //- End section 5


  //- Section 6
  .section-6 
    .table-2 
      table 
        thead
          tr 
            th(class="inner-center")
              input(type="checkbox" class="inner-check")
            th Tên tour
            th Ảnh đại diện
            th Giá
            th Còn lại
            th(class="inner-center") Vị trí
            th(class="inner-center") Trạng thái
            th Xóa  bởi  
            th Hành động
        tbody
          each item in tourList
            tr 
              td(class="inner-center")
                input(type="checkbox" class="inner-check" check-item=item._id)
              td #{item.name}
              td 
                img(src=item.avatar class="inner-avatar")
              td 
                div NL: #{item.priceNewAdult > 0 ? item.priceNewAdult.toLocaleString("vi-VN") : item.priceAdult.toLocaleString("vi-VN")}đ
                div TE: #{item.priceNewChildren > 0 ? item.priceNewChildren.toLocaleString("vi-VN") : item.priceChildren.toLocaleString("vi-VN")}đ  
                div EB: #{item.priceNewBaby > 0 ? item.priceNewBaby.toLocaleString("vi-VN") : item.priceBaby.toLocaleString("vi-VN")}đ
              td 
                div NL: #{item.stockAdult}
                div TE: #{item.stockChildren}
                div EB: #{item.stockBaby}
              td(class="inner-center") #{item.position}
              td(class="inner-center")
                - if(item.status == "active")
                  .badge.badge-green Hoạt động
                - if(item.status == "inactive")
                  .badge.badge-red Tạm dừng
              td 
                div #{item.deletedByFullName}
                div.inner-time #{item.deletedAtFormat}
              td
                .inner-buttons 
                  button(
                    class="inner-undo"
                    button-undo
                    data-api  = `/${pathAdmin}/tour/undo/${item._id}`
                  ) <i class="fa-solid fa-rotate-left"></i>
                  button(
                    class="inner-delete"
                    button-delete 
                    data-api = `/${pathAdmin}/tour/delete-destroy/${item._id}`
                  ) <i class="fa-regular fa-trash-can"></i>
  //- End section 6

  //- Section 7 
  .section-7 
    span(class="inner-label") Hiện thị 1 - 9 của 78
    select(class="inner-pagination")
      option Trang 1
      option Trang 2
      option Trang 3
  //- Section 7