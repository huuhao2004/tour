extends ../layouts/default.pug
include ../mixins/options.pug
include ../mixins/pagination.pug


block main 
  h1.box-title  Quản lý tour

  //- Section 4
  .section-4 
    .inner-wrap 
      .inner-item.inner-label 
        <i class="fa-solid fa-filter"></i>Bộ lọc
      .inner-item
        select(filter-status)
          option(value="") Trạng thái
          option(value="active") Hoạt động
          option(value="inactive") Tạm dừng
      .inner-item
        select(filter-created-by)
          option(value="") Người tạo  
          each item in accountAdminList
            option(value=item._id) #{item.fullName }
      .inner-item.inner-date 
        input(type="date" filter-start-date)
        span -
        input(type="date" filter-end-date)
      .inner-item
        select(filter-category)
          option(value="") Danh mục
          +options(categoryList)
      .inner-item
        select(filter-price)
          option(value="") Mức giá
          option(value="under-2m") Dưới 2 tr
          option(value="2m-4m") Từ 2tr đến 4tr
          option(value="4m-8m") Từ 4tr đến 8tr
          option(value="over-8m") Trên 8tr
      .inner-item.inner-reset(filter-reset)
        <i class="fa-solid fa-rotate-left"></i>Xóa bộ lọc
  //- End section 4

  //- Section 5
  .section-5 
    .inner-wrap 
      .inner-change-status(change-multi data-api=`/${pathAdmin}/tour/change-multi`)
        .inner-item 
          select
            option(value="") -- Hành động --
            option(value="active") Hoạt đông
            option(value="inactive") Dừng hoạt động 
            option(value="delete") Xóa
        .inner-item 
          button Áp dụng
      .inner-search 
        <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm" search)
      .inner-button-create 
        a(href=`/${pathAdmin}/tour/create`) + Tạo mới
      .inner-button-trash 
        a(href=`/${pathAdmin}/tour/trash`) + Thùng rác
  //- End section 5

  //- Section 6
  .section-6 
    .table-2 
      table 
        thead
          tr 
            th(class="inner-center")
              input(type="checkbox" class="inner-check" check-all)
            th Tên tour
            th Ảnh đại diện
            th Giá
            th Còn lại
            th(class="inner-center") Vị trí
            th(class="inner-center") Trạng thái
            th Tạo bởi  
            th Cập nhật bởi
            th Hành động
        tbody
          each item in tourList
            tr 
              td(class="inner-center")
                input(type="checkbox" class="inner-check" check-item=item._id)
              td #{item.name}
              td 
                img(src=item.avatar class="inner-avatar")
              td 
                div NL: #{item.priceNewAdult > 0 ? item.priceNewAdult.toLocaleString("vi-VN") : item.priceAdult.toLocaleString("vi-VN")}đ
                div TE: #{item.priceNewChildren > 0 ? item.priceNewChildren.toLocaleString("vi-VN") : item.priceChildren.toLocaleString("vi-VN")}đ  
                div EB: #{item.priceNewBaby > 0 ? item.priceNewBaby.toLocaleString("vi-VN") : item.priceBaby.toLocaleString("vi-VN")}đ
              td 
                div NL: #{item.stockAdult}
                div TE: #{item.stockChildren}
                div EB: #{item.stockBaby}
              td(class="inner-center") #{item.position}
              td(class="inner-center")
                - if(item.status == "active")
                  .badge.badge-green Hoạt động
                - if(item.status == "inactive")
                  .badge.badge-red Tạm dừng
              td 
                div #{item.createdByFullName}
                div.inner-time #{item.createdAtFormat}
              td 
                div #{item.updatedByFullName}
                div.inner-time #{item.updatedAtFormat}
              td
                .inner-buttons 
                  a(
                    class="inner-edit"
                    href=`/${pathAdmin}/tour/edit/${item._id}`
                  ) <i class="fa-regular fa-pen-to-square"></i>
                  button(
                    class="inner-delete"
                    button-delete
                    data-api  = `/${pathAdmin}/tour/delete/${item._id}`
                  ) <i class="fa-regular fa-trash-can"></i>
  //- End section 6

  //- Section 7 
  .section-7 
    +pagination(objectPagination)
  //- Section 7