extends ../layouts/default.pug

block main 
  h1.box-title Thông tin cá nhân

  //- Section 8
  .section-8 
    form#profile-edit-form
      .inner-group 
        label(class="inner-label" for="fullName") Họ tên
        input(type="text" id="fullName" name="fullName" value="Le Van A") 
      .inner-group 
        label(class="inner-label" for="email") Email
        input(type="text" id="email" name="email" value="levana@gmail.com") 
      .inner-group 
        label(class="inner-label" for="phone") Phone
        input(type="text" id="phone" name="phone" value="0123456789")
      .inner-group 
        label(class="inner-label" for="positionCompany") Chức vụ
        input(type="text" id="positionCompany" name="positionCompany" value="Giám đốc" readonly)
      .inner-group 
        label(class="inner-label" for="role") Nhóm quyền
        input(type="text" id="role" name="role" value="Quản trị viên" readonly)
      .inner-group.inner-two-col
        label(class="inner-label" for="avatar") Ảnh đại diện
        div.inner-upload-image
          input(type="file" id="avatar" name="avatar"  accept="image/*" filepond-image)
      .inner-button.inner-two-col
        button Cập nhật
      
    .inner-back 
      a(href=`/${pathAdmin}/profile/change-password`) Đổi mật khẩu
  //- End section 8